<%- include('./partials/nav') %>

    <h1>
        <%= user.username %>'s dashboard
    </h1>
    <br>
    <div>
        <% recipes.forEach((recipe)=>{ %>
            <div class="rec-container">
                <div class="recipe-box">
                    <h2>
                        <%= recipe.recipeName %>
                    </h2>
                    <a href="/recipes/<%= recipe._id %>">See more</a>
                </div>
            </div>
            <%})%>
    </div>
    </body>

    </html>