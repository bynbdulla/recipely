<%- include('../partials/nav') %>

<div class="container">
    <a href="/recipes/<%= recipe._id %>/edit">Edit</a>
    <a href="/recipes/<%= recipe._id %>/delete">Delete</a>
    <h1>
            <%= recipe.recipeName %>
        </h1>
        <div class="recipe-top">
            <h4>Category: <%= recipe.category%>
            </h4>
            <h4>Serving: <%= recipe.serving%>
            </h4>
            <h4>Cook Time: <%= recipe.cookTime%> mins </h4>
        </div>
        <div class="ingredients">
            <h3>Ingredients: </h3>
            <% allingredients.forEach((item)=>{ %>
                <li>
                    <%= item %>
                </li>
                <br>
                <% }) %>
        </div>
        <div class="instructions">
            <h3>Instructions: </h3>
            <% allinstructions.forEach((item)=>{ %>
                    <%= item %>
                <br>
                <% }) %>
        </div>
    </div>

    </div>


    </body>

    </html>