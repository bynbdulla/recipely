<%- include('../partials/nav') %>

    <h1>Create a New Recipe</h1>
    <form action="/recipes" method="POST">
        <label for="title">Recipe name:</label>
        <input type="text" id="title" name="title" required>
        <br>
        <br>
        <label for="category">Category:</label>
        <select id="category" name="category" required>
            <option value="">Select a category</option>
            <option value="appetizer">Breakfast</option>
            <option value="main-dish">Lunch</option>
            <option value="dessert">Dinner</option>
            <option value="dessert">Dessert</option>
            <option value="dessert">Snack</option>
            <option value="dessert">Soup</option>
            <option value="dessert">Salad</option>
        </select>
        <br>
        <br>
        <label for="image">Image:</label>
        <input type="file" id="image" name="image">
        <br>
        <br>
        <!-- <label for="prepTime">Prep Time:</label>
        <input type="number" id="prepTime" name="prepTime" required>  -->
        <!-- <br>
        <br> -->
        <label for="cookTime">Cook Time:</label>
        <input type="number" id="cookTime" name="cookTime" required> 
        <br>
        <br>
        <label for="ingredients">Ingredients:</label>
        <input type="string" id="ingredients" name="cookTime" required> 
        <br>
        <br>
        <label for="instructions">Instructions:</label>
        <input type="string" id="instructions" name="cookTime" required> 
        <br>
        <br>

        <button type="submit">Create Recipe</button>
</body>
</html>