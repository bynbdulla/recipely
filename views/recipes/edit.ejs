<%- include('../partials/nav') %>

<h2>Edit <%= recipe.recipeName %> recipe</h2>
<form action="/recipes" method="POST">
        Recipe name:
        <input type="text" name="recipeName" required value="<%= recipe.recipeName%>">
        <br>
        <br>
        <label for="category">Category:</label>
        <select id="category" name="category" required>
            <option value="">Select a category</option>
            <option value="breakfast">Breakfast</option>
            <option value="lunch">Lunch</option>
            <option value="dinner">Dinner</option>
            <option value="dessert">Dessert</option>
            <option value="snack">Snack</option>
            <option value="soup">Soup</option>
            <option value="salad">Salad</option>
        </select>
        <br>
        <br>
      <label>Serving: </label>
      <input type="text" name="serving" id="serving" value="<%= recipe.serving %>">
        <!-- <label for="image">Image:</label>
        <input type="file" id="image" name="image"> -->
        <br>
        <br>
        <!-- <label for="prepTime">Prep Time:</label>
        <input type="number" id="prepTime" name="prepTime" required>  -->
        <!-- <br>
        <br> -->
        <label for="cookTime">Cook Time:</label>
        <input type="number" id="cookTime" name="cookTime" required>
        <br>
        <br>
        <label for="ingredients">Ingredients:</label>
        <textarea name="ingredients" id="ingredients"></textarea>
        <br>
        <br>
        <label for="instructions">Instructions:</label>
        <textarea name="instructions" id="instructions"></textarea>
        <br>
        <br>

        <button type="submit">Update the Recipe</button>
        </body>

        </html>